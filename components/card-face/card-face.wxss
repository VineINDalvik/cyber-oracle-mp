.card-wrap {
  position: relative;
  border-radius: 20rpx;
  overflow: hidden;
}
.card-img {
  width: 100%;
  height: 100%;
  display: block;
}
.card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(10,10,15,0.8), transparent, rgba(10,10,15,0.27));
  pointer-events: none;
}
.card-neon-border {
  position: absolute;
  inset: 0;
  border-radius: 20rpx;
  border: 1rpx solid rgba(0,240,255,0.25);
  box-shadow: inset 0 0 30rpx rgba(0,240,255,0.05), 0 0 16rpx rgba(0,240,255,0.1);
  pointer-events: none;
}
.card-name-area {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 16rpx 16rpx;
  background: linear-gradient(to top, #0a0a0f, transparent);
  text-align: center;
}
.card-name {
  font-size: 24rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
  display: block;
}
.card-cyber {
  font-size: 16rpx;
  color: rgba(0,240,255,0.4);
  margin-top: 4rpx;
  display: block;
}
.reversed-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(255,0,170,0.8);
  color: white;
  font-size: 16rpx;
}

/* Card back */
.card-back {
  position: relative;
  border-radius: 20rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #1a1a2e, #16213e, #1a1a2e);
  border: 1rpx solid rgba(0,240,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-pattern {
  position: absolute;
  inset: 0;
  opacity: 0.06;
  background-image: repeating-linear-gradient(45deg, #00f0ff 0, #00f0ff 1px, transparent 0, transparent 50%);
  background-size: 16rpx 16rpx;
}
.back-glyph {
  font-size: 60rpx;
  color: rgba(0,240,255,0.3);
  position: relative;
  z-index: 1;
}
