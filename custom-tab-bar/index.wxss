.tab-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 120rpx;
  background: rgba(18, 18, 31, 0.95);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-top: 1rpx solid rgba(0, 240, 255, 0.1);
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 32rpx;
}

.tab-indicator {
  position: absolute;
  top: 0;
  left: 16rpx;
  right: 16rpx;
  height: 4rpx;
  background: #00f0ff;
  border-radius: 4rpx;
}

.tab-icon {
  font-size: 36rpx;
}

.tab-text {
  font-size: 20rpx;
  font-family: Menlo, monospace;
  color: rgba(224, 224, 255, 0.25);
}

.tab-item.active .tab-text {
  color: #00f0ff;
}
