.page {
  display: flex; flex-direction: column; align-items: center;
  min-height: 100vh; padding: 32rpx 32rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}
.page-title { display: block; font-size: 36rpx; font-weight: bold; margin: 8rpx 0 8rpx; letter-spacing: 8rpx; }
.page-subtitle { display: block; font-size: 22rpx; color: rgba(224,224,255,0.3); margin-bottom: 32rpx; }
.topic-list { width: 100%; }
.topic-item { width: 100%; padding: 28rpx; border-radius: 20rpx; margin-bottom: 16rpx; display: flex; align-items: center; gap: 16rpx; flex-wrap: wrap; }
.t-icon { font-size: 40rpx; }
.t-icon.big { font-size: 60rpx; display: block; text-align: center; margin-bottom: 8rpx; }
.t-name { font-size: 28rpx; font-weight: bold; color: rgba(224,224,255,0.7); }
.t-desc { width: 100%; font-size: 22rpx; color: rgba(224,224,255,0.3); margin-top: 4rpx; }
.phase-title { display: block; text-align: center; font-size: 28rpx; font-weight: bold; margin-bottom: 8rpx; }
.phase-hint { display: block; text-align: center; font-size: 22rpx; color: rgba(224,224,255,0.3); margin-bottom: 24rpx; }
.card-area { display: flex; flex-direction: column; align-items: center; margin-bottom: 24rpx; }
.tap-hint { font-size: 22rpx; color: rgba(0,240,255,0.4); margin-top: 16rpx; }
.result-label { display: block; text-align: center; font-size: 22rpx; color: var(--neon-cyan); margin-bottom: 24rpx; }
.code-box { width: 100%; padding: 28rpx; border-radius: 20rpx; text-align: center; margin-bottom: 24rpx; }
.code-hint { display: block; font-size: 22rpx; color: rgba(224,224,255,0.4); margin-bottom: 12rpx; }
.code-link { display: block; font-size: 18rpx; color: rgba(224,224,255,0.6); word-break: break-all; margin-bottom: 16rpx; }
.code-actions { display: flex; gap: 12rpx; margin-bottom: 12rpx; }
.code-action-btn {
  flex: 1; padding: 20rpx; border-radius: 16rpx; text-align: center;
  font-size: 22rpx; background: rgba(0,240,255,0.1); border: 1rpx solid rgba(0,240,255,0.2); color: rgba(0,240,255,0.8);
}
.code-action-btn.secondary { background: rgba(224,224,255,0.03); border-color: rgba(224,224,255,0.08); color: rgba(224,224,255,0.4); }
.code-expire { display: block; font-size: 16rpx; color: rgba(224,224,255,0.15); }
/* 甲方已选牌提示 */
.a-card-hint {
  display: flex; align-items: center; gap: 12rpx;
  padding: 12rpx 20rpx; border-radius: 12rpx; margin-bottom: 24rpx;
}
.a-card-label { font-size: 18rpx; color: rgba(224,224,255,0.3); }
.divider-row { display: flex; align-items: center; gap: 16rpx; width: 100%; margin-bottom: 20rpx; }
.divider-line { flex: 1; height: 1rpx; background: rgba(224,224,255,0.05); }
.divider-text { font-size: 20rpx; color: rgba(224,224,255,0.15); }
.pair-row { display: flex; align-items: center; justify-content: center; gap: 32rpx; margin-bottom: 24rpx; }
.pair-row.small { gap: 24rpx; }
.pair-item { display: flex; flex-direction: column; align-items: center; }
.pair-label { font-size: 18rpx; color: rgba(224,224,255,0.2); margin-bottom: 8rpx; }
.pair-name { font-size: 18rpx; margin-top: 8rpx; }
.pair-x { font-size: 36rpx; color: #ffb800; }
/* 口令入口 */
.code-entry-divider { display: flex; align-items: center; gap: 16rpx; width: 100%; margin: 24rpx 0 16rpx; }
.code-entry-btn {
  width: 100%; padding: 24rpx; border-radius: 16rpx; text-align: center;
}
.code-entry-text { font-size: 24rpx; color: rgba(224,224,255,0.4); }
/* 口令输入页 */
.code-input-row { display: flex; align-items: center; gap: 16rpx; width: 100%; }
.code-input {
  flex: 1; padding: 20rpx 24rpx; border-radius: 16rpx;
  font-size: 28rpx; color: rgba(224,224,255,0.7); letter-spacing: 8rpx; text-align: center;
}
.code-submit-btn {
  padding: 20rpx 32rpx; border-radius: 16rpx;
  background: rgba(191,0,255,0.1); border: 1rpx solid rgba(191,0,255,0.2);
}
.code-submit-btn.disabled { opacity: 0.3; }
.code-submit-text { font-size: 24rpx; color: #bf00ff; }

.demo-hint { display: block; font-size: 18rpx; color: rgba(224,224,255,0.2); margin-bottom: 20rpx; text-align: center; }
.demo-code { color: rgba(255,184,0,0.7); }
.share-btn-compat {
  width: 100%; padding: 24rpx 0; border-radius: 20rpx;
  background: rgba(18,18,31,0.8);
  border: 1rpx solid rgba(191,0,255,0.15);
  color: rgba(191,0,255,0.7); font-size: 24rpx;
  text-align: center;
  margin-bottom: 8rpx;
}
.share-row { width: 100%; display: flex; flex-direction: column; align-items: center; }
.back-btn { display: block; text-align: center; font-size: 22rpx; color: rgba(224,224,255,0.15); padding: 8rpx 0; margin-top: 20rpx; width: 100%; }
.reset-btn { display: block; text-align: center; font-size: 22rpx; color: rgba(224,224,255,0.15); margin-top: 16rpx; padding: 16rpx; }

/* ====== Share Card Modal ====== */
.sc-mask {
  position: fixed; left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.85);
  display: flex; align-items: flex-end; justify-content: center;
  z-index: 1000;
}
.sc-panel {
  position: fixed; bottom: 0; left: 0; right: 0;
  height: auto; max-height: 85vh;
  background: #0d0d1e;
  border-radius: 40rpx 40rpx 0 0;
  padding: 20rpx 0 0;
  display: flex; flex-direction: column; align-items: center;
  border-top: 1rpx solid rgba(191,0,255,0.12);
  box-sizing: border-box;
  padding-bottom: env(safe-area-inset-bottom, 24rpx);
}
.sc-close {
  position: absolute; top: 28rpx; left: 32rpx;
  width: 60rpx; height: 60rpx; border-radius: 50%;
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.1);
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; color: rgba(224,224,255,0.5); line-height: 1;
  z-index: 10;
}
.sc-top-label {
  display: block; text-align: center;
  font-size: 18rpx; color: rgba(191,0,255,0.4); letter-spacing: 3rpx;
  margin-bottom: 20rpx;
  flex-shrink: 0;
}
.sc-scroll { width: 100%; max-height: 55vh; }
.sc-scroll-padding { height: 24rpx; }
.sc-card-wrap {
  margin: 0 32rpx; border-radius: 28rpx;
  overflow: hidden;
  border: 1rpx solid rgba(191,0,255,0.15);
}
.sc-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 28rpx 12rpx;
  background: linear-gradient(180deg, rgba(10,10,15,1), rgba(16,16,40,1));
}
.sc-brand { font-size: 16rpx; color: rgba(255,255,255,0.15); letter-spacing: 6rpx; }
.sc-date-label { font-size: 18rpx; color: rgba(191,0,255,0.5); }
.sc-pair-row {
  display: flex; justify-content: center; align-items: center; gap: 24rpx;
  padding: 20rpx 16rpx;
  background: linear-gradient(180deg, rgba(16,16,40,1), rgba(12,12,30,1));
}
.sc-pair-item { display: flex; flex-direction: column; align-items: center; }
.sc-pair-name { font-size: 18rpx; color: rgba(0,240,255,0.6); margin-top: 8rpx; }
.sc-pair-name.purple { color: rgba(168,85,247,0.6); }
.sc-pair-x { font-size: 36rpx; color: rgba(255,184,0,0.7); }
.sc-divider {
  height: 1rpx; margin: 0 28rpx;
  background: rgba(191,0,255,0.1);
}
.sc-fortune-text {
  display: block; padding: 28rpx 28rpx 24rpx;
  font-size: 24rpx; color: rgba(224,224,255,0.65);
  line-height: 1.85; text-align: center;
  white-space: pre-wrap; word-break: break-word;
  background: rgba(16,16,42,1);
}
.sc-footer {
  display: flex; align-items: flex-end; justify-content: space-between;
  padding: 12rpx 28rpx 24rpx;
  background: rgba(10,10,24,1);
  border-top: 1rpx solid rgba(191,0,255,0.08);
}
.sc-footer-left { display: flex; flex-direction: column; gap: 4rpx; }
.sc-gz { font-size: 18rpx; color: rgba(191,0,255,0.5); }
.sc-card-name { font-size: 18rpx; color: rgba(0,240,255,0.3); }
.sc-site { font-size: 16rpx; color: rgba(255,255,255,0.1); }
.sc-actions {
  display: flex; gap: 20rpx;
  padding: 24rpx 32rpx 16rpx; width: 100%;
  flex-shrink: 0;
  background: #0d0d1e;
}
.sc-btn-save {
  flex: 1; padding: 28rpx 0; border-radius: 20rpx; text-align: center;
  background: linear-gradient(135deg, rgba(191,0,255,0.12), rgba(168,85,247,0.12));
  border: 1rpx solid rgba(191,0,255,0.25);
  color: rgba(191,0,255,0.85); font-size: 26rpx; font-weight: bold;
}
.sc-btn-save.loading { opacity: 0.5; }
.sc-btn-share {
  flex: 1; padding: 28rpx 0; border-radius: 20rpx !important; text-align: center;
  background: rgba(168,85,247,0.08) !important;
  border: 1rpx solid rgba(168,85,247,0.25) !important;
  color: rgba(168,85,247,0.8) !important; font-size: 26rpx !important; font-weight: bold;
  line-height: 1;
  margin: 0 !important; min-width: 0 !important;
  box-sizing: border-box !important;
}
.sc-btn-share::after { border: none !important; }
.sc-hint {
  display: block; text-align: center;
  font-size: 18rpx; color: rgba(224,224,255,0.18);
  padding: 0 0 16rpx;
  flex-shrink: 0;
  background: #0d0d1e;
}
.reading, .glass-no-blur {
  width: 100%; padding: 28rpx; border-radius: 20rpx; margin-bottom: 16rpx;
  min-height: 200rpx;
  background: rgba(18,18,31,0.92);
  border: 1rpx solid rgba(255,255,255,0.08);
}
.reading-text { font-size: 28rpx; color: rgba(224,224,255,0.7); line-height: 2; white-space: pre-wrap; word-break: break-word; }
.loading-text { font-size: 22rpx; color: rgba(224,224,255,0.3); text-align: center; display: inline; }
.loading-text-wrap { display: flex; align-items: center; justify-content: center; }
.stream-cursor {
  display: inline; font-size: 28rpx; color: rgba(0,240,255,0.8);
  animation: blink-cursor 0.8s steps(2) infinite;
}
@keyframes blink-cursor {
  0% { opacity: 1; }
  100% { opacity: 0; }
}
