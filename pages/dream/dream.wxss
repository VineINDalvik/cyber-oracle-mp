.page {
  display: flex; flex-direction: column; align-items: center;
  min-height: 100vh; padding: 24rpx 32rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* ====== 顶部 Tab ====== */
.dream-top-bar {
  display: flex; align-items: center; gap: 0;
  width: 100%; max-width: 560rpx;
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.dream-tab {
  display: flex; align-items: center;
  padding: 16rpx 28rpx; font-size: 26rpx;
  color: rgba(224,224,255,0.3);
  border-bottom: 3rpx solid transparent;
  margin-bottom: -1rpx;
}
.dream-tab.active {
  color: rgba(168,85,247,0.85);
  border-bottom-color: rgba(168,85,247,0.6);
}
.dream-tab-count {
  font-size: 18rpx; color: rgba(168,85,247,0.5);
}

/* ====== 梦境时间轴 ====== */
.timeline-empty {
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx 40rpx; gap: 20rpx; opacity: 0.5;
}
.timeline-empty-icon { font-size: 72rpx; }
.timeline-empty-text {
  font-size: 22rpx; color: rgba(224,224,255,0.3);
  text-align: center; line-height: 1.8; white-space: pre-wrap;
}

.timeline { width: 100%; padding: 8rpx 0; }
.timeline-item {
  display: flex; gap: 0; margin-bottom: 32rpx; width: 100%;
}

/* 左侧时间轴 */
.tl-left {
  display: flex; flex-direction: column; align-items: center;
  width: 140rpx; flex-shrink: 0; padding-top: 8rpx;
}
.tl-date-wrap {
  display: flex; flex-direction: column; align-items: center; gap: 4rpx;
  margin-bottom: 12rpx;
}
.tl-date { font-size: 18rpx; color: rgba(168,85,247,0.5); }
.tl-time { font-size: 16rpx; color: rgba(224,224,255,0.2); }
.tl-line { width: 2rpx; flex: 1; background: rgba(168,85,247,0.15); min-height: 40rpx; }

/* 内容卡片 */
.tl-card {
  flex: 1; border-radius: 20rpx; padding: 20rpx;
  border: 1rpx solid rgba(168,85,247,0.1);
  margin-left: 8rpx;
}
.tl-card-top { display: flex; gap: 16rpx; margin-bottom: 12rpx; }
.tl-card-img {
  width: 72rpx; height: 108rpx; border-radius: 8rpx; flex-shrink: 0;
  border: 1rpx solid rgba(168,85,247,0.2);
}
.tl-card-img.reversed { transform: rotate(180deg); }
.tl-card-info { display: flex; flex-direction: column; gap: 6rpx; flex: 1; }
.tl-card-name { font-size: 24rpx; font-weight: bold; }
.tl-card-pos { font-size: 18rpx; color: rgba(224,224,255,0.3); }
.tl-dream-excerpt {
  font-size: 20rpx; color: rgba(224,224,255,0.4);
  line-height: 1.5; margin-top: 4rpx;
}
.tl-reading-preview {
  padding: 12rpx; border-radius: 12rpx;
  background: rgba(168,85,247,0.05);
  border: 1rpx solid rgba(168,85,247,0.08);
  margin-bottom: 10rpx;
}
.tl-reading-text {
  font-size: 20rpx; color: rgba(224,224,255,0.4); line-height: 1.6;
}
.tl-tap-hint { font-size: 16rpx; color: rgba(168,85,247,0.3); }
.page-title { display: block; font-size: 36rpx; font-weight: bold; margin: 8rpx 0 8rpx; letter-spacing: 8rpx; }
.page-subtitle { display: block; font-size: 22rpx; color: rgba(224,224,255,0.3); margin-bottom: 24rpx; }

/* Tips card */
.tips-card {
  width: 100%; padding: 24rpx; border-radius: 20rpx; margin-bottom: 16rpx;
}
.tips-title { display: block; font-size: 20rpx; color: rgba(224,224,255,0.35); margin-bottom: 8rpx; }
.tips-text { display: block; font-size: 22rpx; color: rgba(224,224,255,0.25); line-height: 1.6; }
.tips-btns { display: flex; gap: 12rpx; margin-top: 20rpx; }
.tips-btn {
  flex: 1; padding: 14rpx 0; border-radius: 12rpx;
  text-align: center; font-size: 22rpx;
}
.fill-btn {
  background: rgba(191,0,255,0.1); border: 1rpx solid rgba(191,0,255,0.2);
  color: rgba(191,0,255,0.8);
}
.clear-btn {
  background: rgba(18,18,31,0.8); border: 1rpx solid rgba(255,255,255,0.08);
  color: rgba(224,224,255,0.35);
}

.input-box { width: 100%; padding: 28rpx; border-radius: 20rpx; margin-bottom: 24rpx; }
.dream-input { width: 100%; min-height: 200rpx; background: transparent; color: rgba(224,224,255,0.8); font-size: 28rpx; line-height: 1.7; }
.placeholder { color: rgba(224,224,255,0.15); }
.input-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 12rpx; }
.char-count { font-size: 18rpx; color: rgba(224,224,255,0.15); }
.change-hint { font-size: 18rpx; color: rgba(224,224,255,0.2); }

.dream-btn {
  background: linear-gradient(135deg,rgba(191,0,255,0.2),rgba(255,0,170,0.2)) !important;
  border-color: rgba(191,0,255,0.3) !important;
  color: #bf00ff !important;
}
.dream-foot {
  display: block; text-align: center; margin-top: 16rpx;
  font-size: 18rpx; color: rgba(224,224,255,0.15);
}

.analyzing {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; min-height: 60vh;
}
.pulse-circle {
  position: relative;
  width: 160rpx; height: 160rpx; border-radius: 50%;
  border: 2rpx solid rgba(191,0,255,0.4);
  background: radial-gradient(circle, rgba(191,0,255,0.08) 0%, transparent 70%);
  animation: pulse-spin 3s linear infinite, pulse-scale 2s ease-in-out infinite;
}
.pulse-circle::before {
  content: ''; position: absolute;
  left: -20rpx; top: -20rpx; right: -20rpx; bottom: -20rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(236,72,153,0.2);
  animation: pulse-ping 2s ease-out infinite;
}
.pulse-circle::after {
  content: '✦'; position: absolute;
  left: 50%; top: 50%; transform: translate(-50%, -50%);
  font-size: 48rpx; color: rgba(191,0,255,0.6);
  animation: pulse-glow 2s ease-in-out infinite;
}
@keyframes pulse-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
@keyframes pulse-scale {
  0%,100% { box-shadow: 0 0 20rpx rgba(191,0,255,0.1); }
  50% { box-shadow: 0 0 60rpx rgba(236,72,153,0.35), 0 0 120rpx rgba(191,0,255,0.1); }
}
@keyframes pulse-ping {
  0% { transform: scale(1); opacity: 0.6; }
  100% { transform: scale(1.6); opacity: 0; }
}
@keyframes pulse-glow {
  0%,100% { opacity: 0.4; transform: translate(-50%,-50%) scale(1); }
  50% { opacity: 1; transform: translate(-50%,-50%) scale(1.15); }
}
.analyzing-text { font-size: 22rpx; margin-top: 32rpx; }
.back-btn { display: block; text-align: center; font-size: 22rpx; color: rgba(224,224,255,0.15); margin-top: 24rpx; padding: 8rpx; }
.match-title { display: block; text-align: center; font-size: 26rpx; font-weight: bold; margin-bottom: 24rpx; }
.card-area { display: flex; flex-direction: column; align-items: center; margin-bottom: 24rpx; }
.dream-excerpt { width: 100%; padding: 20rpx 24rpx; border-radius: 16rpx; margin-bottom: 24rpx; background: rgba(191,0,255,0.05) !important; border-color: rgba(191,0,255,0.1) !important; }
.excerpt-label { display: block; font-size: 18rpx; color: rgba(224,224,255,0.3); margin-bottom: 8rpx; }
.excerpt-text { font-size: 22rpx; color: rgba(224,224,255,0.5); line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
.teaser { width: 100%; padding: 24rpx; border-radius: 20rpx; margin-bottom: 24rpx; border-style: dashed; }
.teaser-text { font-size: 24rpx; color: rgba(224,224,255,0.3); line-height: 1.6; text-align: center; }
.reading, .glass-no-blur {
  width: 100%; padding: 28rpx; border-radius: 20rpx; margin-bottom: 24rpx;
  min-height: 200rpx;
  background: rgba(18,18,31,0.92);
  border: 1rpx solid rgba(255,255,255,0.08);
}
.reading-label { display: block; font-size: 20rpx; color: var(--neon-cyan); margin-bottom: 16rpx; }
.reading-text { font-size: 28rpx; color: rgba(224,224,255,0.7); line-height: 2; white-space: pre-wrap; word-break: break-word; }
.loading-text { font-size: 22rpx; color: rgba(224,224,255,0.3); display: inline; }
.loading-text-wrap { display: flex; align-items: center; justify-content: center; }
.stream-cursor {
  display: inline; font-size: 28rpx; color: rgba(191,0,255,0.8);
  animation: blink-cursor 0.8s steps(2) infinite;
}
@keyframes blink-cursor {
  0% { opacity: 1; }
  100% { opacity: 0; }
}
.action-row { display: flex; gap: 16rpx; width: 100%; }
.action-row .btn-secondary { flex: 1; }
.share-btn-sm {
  flex: 1; padding: 24rpx 0; border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(191,0,255,0.15), rgba(255,0,170,0.15));
  border: 1rpx solid rgba(191,0,255,0.2);
  color: #bf00ff; font-size: 24rpx;
  text-align: center;
}

/* ====== Share Card Modal ====== */
.sc-mask {
  position: fixed; left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.85);
  display: flex; align-items: flex-end; justify-content: center;
  z-index: 1000;
}
.sc-panel {
  position: fixed; bottom: 0; left: 0; right: 0;
  height: 90vh;
  background: #0d0d1e;
  border-radius: 40rpx 40rpx 0 0;
  padding: 20rpx 0 0;
  display: flex; flex-direction: column; align-items: center;
  border-top: 1rpx solid rgba(168,85,247,0.12);
  box-sizing: border-box;
}
.sc-close {
  position: absolute; top: 28rpx; left: 32rpx;
  width: 60rpx; height: 60rpx; border-radius: 50%;
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.1);
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; color: rgba(224,224,255,0.5); line-height: 1;
}
.sc-top-label {
  display: block; text-align: center;
  font-size: 18rpx; color: rgba(168,85,247,0.4); letter-spacing: 3rpx;
  margin-bottom: 20rpx;
}
.sc-scroll { width: 100%; height: calc(90vh - 270rpx); }
.sc-scroll-padding { height: 24rpx; }
.sc-card-wrap {
  margin: 0 32rpx; border-radius: 28rpx;
  overflow: hidden;
  border: 1rpx solid rgba(168,85,247,0.15);
}
.sc-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 28rpx 12rpx;
  background: linear-gradient(180deg, rgba(10,10,15,1), rgba(16,16,40,1));
}
.sc-brand { font-size: 16rpx; color: rgba(255,255,255,0.15); letter-spacing: 6rpx; }
.sc-date-label { font-size: 18rpx; color: rgba(168,85,247,0.5); }
.sc-card-face {
  display: flex; justify-content: center; align-items: center;
  padding: 20rpx 0 28rpx;
  background: linear-gradient(180deg, rgba(16,16,40,1), rgba(12,12,30,1));
}
.sc-divider {
  height: 1rpx; margin: 0 28rpx;
  background: rgba(168,85,247,0.1);
}
.sc-fortune-text {
  display: block; padding: 28rpx 28rpx 24rpx;
  font-size: 24rpx; color: rgba(224,224,255,0.65);
  line-height: 1.85; text-align: center;
  white-space: pre-wrap; word-break: break-word;
  background: rgba(16,16,42,1);
}
.sc-footer {
  display: flex; align-items: flex-end; justify-content: space-between;
  padding: 12rpx 28rpx 24rpx;
  background: rgba(10,10,24,1);
  border-top: 1rpx solid rgba(168,85,247,0.08);
}
.sc-footer-left { display: flex; flex-direction: column; gap: 4rpx; }
.sc-gz { font-size: 18rpx; color: rgba(168,85,247,0.5); }
.sc-card-name { font-size: 18rpx; color: rgba(0,240,255,0.3); }
.sc-site { font-size: 16rpx; color: rgba(255,255,255,0.1); }
.sc-actions {
  display: flex; gap: 20rpx;
  padding: 24rpx 32rpx 8rpx; width: 100%;
}
.sc-btn-save {
  flex: 1; padding: 28rpx 0; border-radius: 20rpx; text-align: center;
  background: linear-gradient(135deg, rgba(168,85,247,0.12), rgba(191,0,255,0.12));
  border: 1rpx solid rgba(168,85,247,0.25);
  color: rgba(168,85,247,0.85); font-size: 26rpx; font-weight: bold;
}
.sc-btn-save.loading { opacity: 0.5; }
.sc-btn-share {
  flex: 1; padding: 28rpx 0; border-radius: 20rpx !important; text-align: center;
  background: rgba(191,0,255,0.08) !important;
  border: 1rpx solid rgba(191,0,255,0.25) !important;
  color: rgba(191,0,255,0.8) !important; font-size: 26rpx !important; font-weight: bold;
  line-height: 1;
  margin: 0 !important; min-width: 0 !important;
  box-sizing: border-box !important;
}
.sc-btn-share::after { border: none !important; }
.sc-hint {
  display: block; text-align: center;
  font-size: 18rpx; color: rgba(224,224,255,0.18);
  padding: 4rpx 0 env(safe-area-inset-bottom, 24rpx);
}
