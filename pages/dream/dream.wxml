<view class="page">
  <!-- 顶部历史入口 -->
  <view class="dream-top-bar" wx:if="{{phase === 'input' || showHistory}}">
    <view class="dream-tab {{!showHistory ? 'active' : ''}}" bindtap="toggleHistory">
      <text>解梦</text>
    </view>
    <view class="dream-tab {{showHistory ? 'active' : ''}}" bindtap="toggleHistory">
      <text>梦境轨迹</text>
      <text class="dream-tab-count" wx:if="{{dreamHistory.length > 0}}"> {{dreamHistory.length}}</text>
    </view>
  </view>

  <!-- 梦境时间轴 -->
  <block wx:if="{{showHistory}}">
    <view class="timeline-empty" wx:if="{{dreamHistory.length === 0}}">
      <text class="timeline-empty-icon">🌙</text>
      <text class="timeline-empty-text mono">还没有梦境记录\n解析第一个梦境后会出现在这里</text>
    </view>
    <view class="timeline" wx:else>
      <view class="timeline-item" wx:for="{{dreamHistory}}" wx:key="dateStr" data-item="{{item}}" bindtap="viewHistoryItem">
        <!-- 时间轴左侧 -->
        <view class="tl-left">
          <view class="tl-date-wrap">
            <text class="tl-date mono">{{item.dateStr}}</text>
            <text class="tl-time mono">{{item.timeStr}}</text>
          </view>
          <view class="tl-line"></view>
        </view>
        <!-- 内容卡片 -->
        <view class="tl-card glass">
          <view class="tl-card-top">
            <image class="tl-card-img {{item.isReversed ? 'reversed' : ''}}"
                   src="{{item.imageUrl}}" mode="aspectFill" />
            <view class="tl-card-info">
              <text class="tl-card-name neon-text-purple">赛博·{{item.cardName}}</text>
              <text class="tl-card-pos mono">{{item.isReversed ? '⟲ 逆位' : '⬆ 正位'}}</text>
              <text class="tl-dream-excerpt">{{item.dreamExcerpt}}</text>
            </view>
          </view>
          <view class="tl-reading-preview" wx:if="{{item.reading}}">
            <text class="tl-reading-text">{{item.reading.slice(0,60)}}…</text>
          </view>
          <text class="tl-tap-hint mono">点击查看完整解读 ›</text>
        </view>
      </view>
    </view>
  </block>

  <!-- Input -->
  <block wx:if="{{phase === 'input' && !showHistory}}">
    <text class="section-label">DREAM DECODER</text>
    <text class="page-title neon-text-purple">梦境解码</text>
    <text class="page-subtitle">周公解梦 × 赛博塔罗，双重视角解析</text>

    <!-- Tips card -->
    <view class="tips-card glass">
      <text class="tips-title mono">怎么写更准？</text>
      <text class="tips-text">写清楚「场景」「人物/物件」「情绪」「结尾」，越具体越好。</text>
      <view class="tips-btns">
        <view class="tips-btn fill-btn" bindtap="fillExample">一键填充示例</view>
        <view class="tips-btn clear-btn" bindtap="clearDream">清空</view>
      </view>
    </view>

    <view class="input-box glass">
      <textarea class="dream-input" value="{{dream}}" bindinput="onDreamInput"
        placeholder="{{hint}}" placeholder-class="placeholder" maxlength="500" />
      <view class="input-footer">
        <text class="char-count mono">{{dream.length}}/500</text>
        <text class="change-hint mono" bindtap="changeHint">换个示例</text>
      </view>
    </view>
    <view class="btn-primary dream-btn" bindtap="startAnalysis">
      🔮 解析梦境
    </view>
    <text class="dream-foot mono">解析后可「生成梦境分享图」发朋友圈</text>
  </block>

  <!-- Analyzing -->
  <view class="analyzing" wx:if="{{phase === 'analyzing'}}">
    <view class="pulse-circle"></view>
    <text class="analyzing-text mono neon-text-purple">正在解析梦境信号...</text>
    <text class="back-btn mono" bindtap="reset">⟵ 返回</text>
  </view>

  <!-- Result -->
  <block wx:if="{{phase === 'result' && result}}">
    <text class="section-label">DREAM MATCHED</text>
    <text class="match-title neon-text-purple">你的梦境对应：赛博·{{result.card.name}}</text>
    <view class="card-area">
      <card-face cardId="{{result.card.id}}" reversed="{{result.isReversed}}" size="md" />
    </view>
    <view class="dream-excerpt glass">
      <text class="excerpt-label mono">你的梦境：</text>
      <text class="excerpt-text">{{dream}}</text>
    </view>

    <block wx:if="{{!reading}}">
      <view class="teaser glass">
        <text class="teaser-text">赛博·{{result.card.name}}与你的梦境产生了共振，周公解梦 × 塔罗原型的双重解析即将揭示...</text>
      </view>
      <view class="btn-primary dream-btn" bindtap="requestReading">
        📖 查看梦境解读
      </view>
    </block>
    <view class="reading glass-no-blur" wx:if="{{isLoading && !reading}}">
      <text class="reading-label mono">周公 × 塔罗 双重解析</text>
      <view class="loading-text-wrap">
        <text class="loading-text mono">正在深度解析</text>
        <text class="stream-cursor">▍</text>
      </view>
    </view>
    <block wx:elif="{{reading}}">
      <view class="reading glass-no-blur">
        <text class="reading-label mono">周公 × 塔罗 双重解析</text>
        <text class="reading-text">{{reading}}</text>
      </view>
    </block>

    <view class="action-row">
      <view class="btn-secondary" bindtap="reset">⟳ 解析新梦境</view>
      <view class="share-btn-sm" bindtap="showShareCard">💾 分享</view>
    </view>

    <!-- Share Card Modal -->
    <view class="sc-mask" wx:if="{{showShareCard}}" bindtap="closeShareCard">
      <view class="sc-panel" catchtap="noop">
        <view class="sc-close" bindtap="closeShareCard">×</view>
        <text class="sc-top-label mono">🌙 梦境解码</text>

        <scroll-view class="sc-scroll" scroll-y enhanced>
          <view class="sc-card-wrap glass">
            <view class="sc-header">
              <text class="sc-brand mono">CYBER ORACLE</text>
              <text class="sc-date-label mono">梦境解码</text>
            </view>

            <view class="sc-card-face">
              <card-face cardId="{{result.card.id}}" reversed="{{result.isReversed}}" size="lg" />
            </view>

            <view class="sc-divider"></view>

            <text class="sc-fortune-text">{{reading || '梦境正在解码中...'}}</text>

            <view class="sc-footer">
              <view class="sc-footer-left">
                <text class="sc-gz mono">赛博·{{result.card.name}}</text>
                <text class="sc-card-name mono">{{result.isReversed ? '⟲ 逆位' : '⬆ 正位'}}</text>
              </view>
              <text class="sc-site mono">cyber.vinex.top</text>
            </view>
          </view>
          <view class="sc-scroll-padding"></view>
        </scroll-view>

        <view class="sc-actions">
          <view class="sc-btn-save {{shareCardLoading ? 'loading' : ''}}" bindtap="saveShareCard">
            <text wx:if="{{shareCardLoading}}">⏳ 生成中...</text>
            <text wx:elif="{{shareCardPath}}">💾 再次保存</text>
            <text wx:else>💾 保存到相册</text>
          </view>
          <button class="sc-btn-share" open-type="share">📤 分享给朋友</button>
        </view>
        <text class="sc-hint mono">保存后可发图片给朋友 · 长按预览图也可保存</text>
      </view>
    </view>
  </block>

  <view class="tip-row mono" bindtap="previewTip" wx:if="{{false}}">☕ 赞赏支持（点击查看二维码）</view>
</view>

