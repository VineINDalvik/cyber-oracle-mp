.page {
  min-height: 100vh;
  padding: 24rpx 32rpx;
  padding-bottom: calc(80rpx + env(safe-area-inset-bottom));
  display: flex; flex-direction: column;
}

/* Hero */
.hero {
  display: flex; align-items: center; gap: 28rpx;
  padding: 32rpx; border-radius: 24rpx; margin-bottom: 24rpx;
}
.avatar-wrap {
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: linear-gradient(135deg, rgba(0,240,255,0.15), rgba(168,85,247,0.15));
  border: 2rpx solid rgba(0,240,255,0.2);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.avatar-glyph { font-size: 44rpx; color: rgba(0,240,255,0.6); }
.user-info { display: flex; flex-direction: column; gap: 12rpx; }
.user-id { font-size: 22rpx; color: rgba(224,224,255,0.4); }
.member-badge {
  display: inline-flex; align-items: center;
  padding: 4rpx 20rpx; border-radius: 20rpx; font-size: 20rpx;
}
.member-badge.free {
  background: rgba(255,255,255,0.05); border: 1rpx solid rgba(255,255,255,0.1);
  color: rgba(224,224,255,0.35);
}
.member-badge.pro {
  background: linear-gradient(135deg, rgba(255,184,0,0.15), rgba(233,69,96,0.15));
  border: 1rpx solid rgba(255,184,0,0.3);
  color: rgba(255,184,0,0.85);
}

/* Stats */
.stats-row {
  display: flex; gap: 16rpx; margin-bottom: 32rpx;
}
.stat-item {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  padding: 24rpx 12rpx; border-radius: 20rpx; gap: 8rpx;
}
.stat-num { font-size: 36rpx; font-weight: bold; }
.stat-label { font-size: 18rpx; color: rgba(224,224,255,0.3); }

/* Section Title */
.section-title {
  font-size: 18rpx; color: rgba(224,224,255,0.25);
  letter-spacing: 3rpx; margin: 8rpx 8rpx 12rpx;
}

/* Menu */
.menu-card {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 24rpx; border-radius: 20rpx; margin-bottom: 24rpx;
  background: linear-gradient(135deg, rgba(0,240,255,0.04), rgba(168,85,247,0.04));
  border: 1rpx solid rgba(0,240,255,0.12);
}
.menu-group {
  border-radius: 20rpx; margin-bottom: 24rpx; overflow: hidden;
}
.menu-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 24rpx;
}
.menu-divider {
  height: 1rpx; background: rgba(255,255,255,0.05); margin: 0 24rpx;
}
.menu-left { display: flex; align-items: center; gap: 20rpx; }
.menu-icon { font-size: 36rpx; }
.menu-text-wrap { display: flex; flex-direction: column; gap: 4rpx; }
.menu-title { font-size: 28rpx; color: rgba(224,224,255,0.8); }
.menu-sub { font-size: 20rpx; color: rgba(224,224,255,0.35); }
.menu-sub.dim { color: rgba(224,224,255,0.2); }
.menu-arrow { font-size: 36rpx; color: rgba(224,224,255,0.3); }
.menu-val { font-size: 22rpx; color: rgba(0,240,255,0.4); }

/* Logout */
.logout-btn {
  margin: 16rpx 0; padding: 28rpx;
  text-align: center; border-radius: 20rpx;
  background: rgba(255,50,50,0.04); border: 1rpx solid rgba(255,50,50,0.1);
  color: rgba(255,100,100,0.5); font-size: 26rpx;
}

/* 登录状态 */
.login-status-row { display: flex; align-items: center; gap: 8rpx; margin-bottom: 4rpx; }
.login-dot { font-size: 18rpx; }
.dot-green { color: #00e87a; }
.dot-yellow { color: rgba(255,184,0,0.7); }
.login-label { font-size: 20rpx; color: rgba(224,224,255,0.45); }

/* 登录说明条 */
.login-tip {
  display: flex; align-items: flex-start; gap: 12rpx;
  padding: 16rpx 20rpx; border-radius: 14rpx; margin-bottom: 20rpx;
  border: 1rpx solid rgba(0,240,255,0.06);
}
.login-tip-icon { font-size: 26rpx; flex-shrink: 0; }
.login-tip-text { font-size: 20rpx; color: rgba(224,224,255,0.28); line-height: 1.6; }

/* 生辰档案弹窗 */
.birth-mask {
  position: fixed; left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.72); display: flex;
  align-items: flex-end; justify-content: center; z-index: 200;
}
.birth-panel {
  width: 100%; padding: 40rpx 40rpx 60rpx;
  border-radius: 32rpx 32rpx 0 0;
  display: flex; flex-direction: column; gap: 24rpx;
}
.birth-title {
  font-size: 32rpx; font-weight: bold;
  color: rgba(224,224,255,0.9); text-align: center;
}
.birth-hint {
  font-size: 20rpx; color: rgba(224,224,255,0.3);
  text-align: center; line-height: 1.5;
}
.birth-field { display: flex; flex-direction: column; gap: 10rpx; }
.birth-label { font-size: 20rpx; color: rgba(0,240,255,0.5); }
.birth-input {
  padding: 20rpx 24rpx; border-radius: 16rpx;
  font-size: 26rpx; color: rgba(224,224,255,0.85);
  border: 1rpx solid rgba(0,240,255,0.15);
}
.birth-ph { color: rgba(224,224,255,0.2) !important; }
.birth-picker {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 24rpx; border-radius: 16rpx;
  border: 1rpx solid rgba(0,240,255,0.15);
}
.birth-picker-val { font-size: 26rpx; color: rgba(224,224,255,0.85); }
.birth-picker-arrow { font-size: 32rpx; color: rgba(224,224,255,0.3); }
.birth-actions { display: flex; flex-direction: column; gap: 12rpx; margin-top: 8rpx; }
.birth-btn-save { font-size: 28rpx; }
.birth-btn-clear {
  text-align: center; font-size: 22rpx;
  color: rgba(224,224,255,0.25); padding: 12rpx;
}

/* Confirm Modal */
.confirm-mask {
  position: fixed; left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7); display: flex;
  align-items: center; justify-content: center; z-index: 100;
}
.confirm-panel {
  width: 560rpx; padding: 40rpx 32rpx 32rpx;
  border-radius: 28rpx; display: flex; flex-direction: column; align-items: center;
}
.confirm-title { font-size: 30rpx; color: rgba(224,224,255,0.85); margin-bottom: 12rpx; }
.confirm-sub { font-size: 20rpx; color: rgba(224,224,255,0.3); text-align: center; line-height: 1.6; margin-bottom: 32rpx; }
.confirm-btns { display: flex; gap: 16rpx; width: 100%; }
.confirm-btn-cancel {
  flex: 1; padding: 24rpx; text-align: center; border-radius: 16rpx;
  background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08);
  color: rgba(224,224,255,0.4); font-size: 26rpx;
}
.confirm-btn-ok {
  flex: 1; padding: 24rpx; text-align: center; border-radius: 16rpx;
  background: rgba(255,50,50,0.1); border: 1rpx solid rgba(255,50,50,0.2);
  color: rgba(255,100,100,0.8); font-size: 26rpx;
}
