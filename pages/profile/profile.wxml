<view class="page">
  <!-- 顶部用户信息 -->
  <view class="hero glass">
    <view class="avatar-wrap">
      <text class="avatar-glyph">☰</text>
    </view>
    <view class="user-info">
      <view class="login-status-row">
        <text class="login-dot {{isLoggedIn ? 'dot-green' : 'dot-yellow'}}">●</text>
        <text class="login-label mono">{{isLoggedIn ? '微信已自动连接' : '连接中…'}}</text>
      </view>
      <text class="user-id mono">{{openid}}</text>
      <view class="member-badge {{memberLevel === '免费版' ? 'free' : 'pro'}}">
        <text>{{memberLevel}}</text>
      </view>
    </view>
  </view>

  <!-- 微信登录说明 -->
  <view class="login-tip glass">
    <text class="login-tip-icon">ℹ️</text>
    <text class="login-tip-text">微信小程序会自动完成身份连接，无需额外登录操作。你的数据与微信账号绑定，换机后可自动同步。</text>
  </view>

  <!-- 数据统计 -->
  <view class="stats-row">
    <view class="stat-item glass">
      <text class="stat-num neon-text">{{totalReadings}}</text>
      <text class="stat-label mono">总解读次数</text>
    </view>
    <view class="stat-item glass">
      <text class="stat-num neon-text">{{seenCards}}/22</text>
      <text class="stat-label mono">已见牌种</text>
    </view>
    <view class="stat-item glass">
      <text class="stat-num neon-text">{{checkinStreak}}</text>
      <text class="stat-label mono">连续签到天</text>
    </view>
  </view>

  <!-- 会员订阅 -->
  <view class="section-title mono">会员订阅</view>
  <view class="menu-card glass" bindtap="showSubscribeTip">
    <view class="menu-left">
      <text class="menu-icon">💎</text>
      <view class="menu-text-wrap">
        <text class="menu-title">升级会员</text>
        <text class="menu-sub mono">无限解读 · 专属报告 · 月度运势</text>
      </view>
    </view>
    <text class="menu-arrow neon-text">›</text>
  </view>

  <!-- 个人设置 -->
  <view class="section-title mono">个人设置</view>
  <view class="menu-group glass">
    <view class="menu-item" bindtap="openBirthEdit">
      <view class="menu-left">
        <text class="menu-icon">✨</text>
        <view class="menu-text-wrap">
          <text class="menu-title">生辰档案</text>
          <text class="menu-sub mono" wx:if="{{birthHasFilled}}">{{birthDate}} {{birthTime}} · 已填写</text>
          <text class="menu-sub mono dim" wx:else>未填写，填写后解读更准确</text>
        </view>
      </view>
      <text class="menu-arrow mono">›</text>
    </view>

    <view class="menu-divider"></view>

    <view class="menu-item">
      <view class="menu-left">
        <text class="menu-icon">💳</text>
        <view class="menu-text-wrap">
          <text class="menu-title">剩余积分</text>
          <text class="menu-sub mono">{{credits}} 点 · 每次深度解读消耗1点</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="section-title mono">关于</view>
  <view class="menu-group glass">
    <view class="menu-item">
      <view class="menu-left">
        <text class="menu-icon">🌐</text>
        <text class="menu-title">网页版</text>
      </view>
      <text class="menu-val mono">cyber.vinex.top</text>
    </view>

    <view class="menu-divider"></view>

    <view class="menu-item">
      <view class="menu-left">
        <text class="menu-icon">📋</text>
        <text class="menu-title">版本</text>
      </view>
      <text class="menu-val mono">v1.0</text>
    </view>
  </view>

  <!-- 退出 -->
  <view class="logout-btn" bindtap="showLogoutConfirm">退出登录</view>

  <view style="height:60rpx"></view>

  <!-- ── 生辰档案弹窗 ─── -->
  <view class="birth-mask" wx:if="{{showBirth}}" bindtap="closeBirth">
    <view class="birth-panel glass" catchtap="noop">
      <text class="birth-title">生辰档案</text>
      <text class="birth-hint mono">填写后 AI 解读会加入命盘参考，更贴合你的能量场</text>

      <view class="birth-field">
        <text class="birth-label mono">出生日期</text>
        <input class="birth-input glass"
          placeholder="如 1995-08-15"
          placeholder-class="birth-ph"
          value="{{editBirth.birthDate}}"
          bindinput="onBirthDateInput"
          type="text"
        />
      </view>

      <view class="birth-field">
        <text class="birth-label mono">出生时辰（可选）</text>
        <picker mode="selector" range="{{shichenOptions}}" range-key="label"
          value="{{shichenIdx}}" bindchange="onShichenChange">
          <view class="birth-picker glass">
            <text class="{{editBirth.birthTime ? 'birth-picker-val' : 'birth-ph'}}">
              {{editBirth.birthTime ? shichenOptions[shichenIdx].label : '选择时辰'}}
            </text>
            <text class="birth-picker-arrow mono">›</text>
          </view>
        </picker>
      </view>

      <view class="birth-actions">
        <view class="birth-btn-save btn-primary" bindtap="saveBirthProfile">保存</view>
        <view class="birth-btn-clear" bindtap="clearBirthProfile">清空档案</view>
      </view>
    </view>
  </view>

  <!-- 退出确认弹窗 -->
  <view class="confirm-mask" wx:if="{{showLogoutConfirm}}" bindtap="cancelLogout">
    <view class="confirm-panel glass" catchtap="noop">
      <text class="confirm-title">确定退出登录？</text>
      <text class="confirm-sub mono">退出后本地数据会保留，重新登录可同步云端数据</text>
      <view class="confirm-btns">
        <view class="confirm-btn-cancel" bindtap="cancelLogout">取消</view>
        <view class="confirm-btn-ok" bindtap="confirmLogout">退出</view>
      </view>
    </view>
  </view>
</view>
