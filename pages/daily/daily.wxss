.page {
  display: flex; flex-direction: column; align-items: center;
  min-height: 100vh; padding: 32rpx 40rpx 160rpx;
  position: relative;
}
.header { text-align: center; margin-bottom: 32rpx; position: relative; width: 100%; }

/* 右上角设置入口 */
.profile-entry {
  position: absolute; right: -8rpx; top: -4rpx;
  width: 68rpx; height: 68rpx; border-radius: 50%;
  background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08);
  display: flex; align-items: center; justify-content: center;
  z-index: 10;
}
.profile-entry-icon { font-size: 32rpx; color: rgba(224,224,255,0.3); }
.date { display: block; font-size: 22rpx; color: rgba(224,224,255,0.5); margin: 8rpx 0 16rpx; }
.ganzhi-badge {
  display: inline-flex; align-items: center; gap: 12rpx;
  padding: 12rpx 24rpx; border-radius: 16rpx;
}
.gz-text { color: #ffb800; font-size: 28rpx; font-weight: bold; }
.gz-sep { color: rgba(224,224,255,0.2); font-size: 18rpx; }
.gz-wx { color: rgba(0,240,255,0.6); font-size: 20rpx; }
.gz-detail { color: rgba(224,224,255,0.3); font-size: 18rpx; }

/* Profile buttons */
.profile-btns {
  display: flex; align-items: center; justify-content: center;
  gap: 16rpx; margin-top: 24rpx;
}
.profile-btn {
  padding: 14rpx 24rpx; border-radius: 20rpx;
  font-size: 22rpx; color: rgba(224,224,255,0.55);
}
.birth-btn {
  background: linear-gradient(135deg, rgba(168,85,247,0.1), rgba(0,240,255,0.1));
  border: 1rpx solid rgba(168,85,247,0.15);
}
.daily-btn { font-size: 22rpx; }
.profile-tag { font-size: 20rpx; }
.profile-tag.gold { color: rgba(255,184,0,0.6); }
.profile-tag.cyan { color: rgba(0,240,255,0.4); }
.profile-tag.dim { color: rgba(224,224,255,0.2); }

.status-hint {
  margin-top: 12rpx;
  font-size: 18rpx; color: rgba(224,224,255,0.2);
}

/* Card area */
.card-area { margin-bottom: 32rpx; }
.pick-scroll { width: 100%; white-space: nowrap; }
.pick-row { display: inline-flex; gap: 16rpx; padding: 8rpx 16rpx; }
.pick-item { display: inline-block; }
.pick-hint { display: block; text-align: center; font-size: 20rpx; color: rgba(224,224,255,0.3); margin-top: 8rpx; }

.fortune {
  text-align: center; max-width: 560rpx;
  font-size: 28rpx; color: rgba(224,224,255,0.7);
  line-height: 1.7; margin-bottom: 24rpx;
}
.label-area { margin-bottom: 32rpx; }
.derivation {
  text-align: center; font-size: 18rpx;
  color: rgba(224,224,255,0.15); margin-bottom: 24rpx;
  max-width: 560rpx; line-height: 1.6;
}

/* Calendar card */
.calendar-card {
  width: 100%; max-width: 560rpx;
  padding: 24rpx; border-radius: 20rpx;
  margin-bottom: 24rpx;
}
.calendar-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 16rpx;
}
.calendar-title { font-size: 18rpx; color: rgba(224,224,255,0.3); }
.calendar-hint { font-size: 18rpx; color: rgba(224,224,255,0.15); }
.calendar-row { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 12rpx; align-items: center; }
.tag-yi {
  font-size: 18rpx; padding: 4rpx 16rpx; border-radius: 8rpx;
  color: rgba(0,240,255,0.6);
  background: rgba(0,240,255,0.05); border: 1rpx solid rgba(0,240,255,0.1);
}
.tag-ji {
  font-size: 18rpx; padding: 4rpx 16rpx; border-radius: 8rpx;
  color: rgba(233,69,96,0.6);
  background: rgba(233,69,96,0.05); border: 1rpx solid rgba(233,69,96,0.1);
}
.tag-item {
  font-size: 18rpx; padding: 4rpx 16rpx; border-radius: 8rpx;
  color: rgba(224,224,255,0.35);
  background: rgba(224,224,255,0.05); border: 1rpx solid rgba(224,224,255,0.1);
}
.calendar-advice { margin-top: 8rpx; }
.advice-label {
  display: inline-block; font-size: 18rpx; padding: 4rpx 16rpx; border-radius: 8rpx;
  color: rgba(233,69,96,0.7); border: 1rpx solid rgba(233,69,96,0.3);
  margin-right: 8rpx; vertical-align: middle;
}
.advice-text {
  font-size: 20rpx; color: rgba(224,224,255,0.45); line-height: 1.6;
}

.teaser {
  width: 100%; max-width: 560rpx;
  padding: 24rpx; border-radius: 20rpx; margin-bottom: 24rpx;
  border-style: dashed;
}
.teaser-text { font-size: 24rpx; color: rgba(224,224,255,0.3); line-height: 1.6; text-align: center; }
.btn-row { display: flex; gap: 16rpx; width: 100%; max-width: 560rpx; margin-bottom: 32rpx; }
.btn-row .btn-primary { flex: 1; }
.share-btn {
  padding: 24rpx 32rpx !important; border-radius: 20rpx !important;
  background: rgba(18,18,31,0.8) !important;
  border: 1rpx solid rgba(0,240,255,0.1) !important;
  color: rgba(224,224,255,0.4) !important;
  font-size: 24rpx !important;
  line-height: 1 !important;
}
.reading, .glass-no-blur {
  width: 100%; max-width: 560rpx;
  padding: 28rpx; border-radius: 20rpx; margin-bottom: 32rpx;
  min-height: 200rpx;
  background: rgba(18,18,31,0.92);
  border: 1rpx solid rgba(255,255,255,0.08);
}
.reading-text {
  font-size: 28rpx; color: rgba(224,224,255,0.7); line-height: 2;
  white-space: pre-wrap; word-break: break-word;
}
.loading-text { font-size: 22rpx; color: rgba(224,224,255,0.3); text-align: center; display: inline; }
.loading-text-wrap { display: flex; align-items: center; justify-content: center; }
.stream-cursor {
  display: inline; font-size: 28rpx; color: rgba(0,240,255,0.8);
  animation: blink-cursor 0.8s steps(2) infinite;
}
@keyframes blink-cursor {
  0% { opacity: 1; }
  100% { opacity: 0; }
}
.collection-bar {
  width: 100%; max-width: 560rpx;
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 24rpx; border-radius: 16rpx;
}
.coll-left { display: flex; flex-direction: column; gap: 4rpx; }
.coll-label { font-size: 20rpx; color: rgba(224,224,255,0.4); }
.coll-sub { font-size: 16rpx; color: rgba(224,224,255,0.18); }
.coll-arrow { font-size: 28rpx; color: rgba(224,224,255,0.2); }

/* ====== 7天牌历 ====== */
.week-cal {
  width: 100%; max-width: 680rpx;
  border-radius: 24rpx; padding: 24rpx 20rpx 20rpx;
  margin-bottom: 28rpx;
}
.week-cal-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 20rpx; padding: 0 8rpx;
}
.week-cal-title { font-size: 22rpx; color: rgba(224,224,255,0.45); }
.week-cal-sub { font-size: 18rpx; color: rgba(0,240,255,0.35); }

.week-cal-scroll { width: 100%; white-space: nowrap; }
.week-cal-row { display: inline-flex; gap: 12rpx; padding: 4rpx 4rpx; }

.week-day-item {
  display: inline-flex; flex-direction: column; align-items: center;
  width: 120rpx; gap: 6rpx;
  padding: 14rpx 8rpx 12rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
  background: rgba(255,255,255,0.02);
  flex-shrink: 0;
}
.week-day-item.today {
  border-color: rgba(0,240,255,0.2);
  background: rgba(0,240,255,0.04);
}
.week-day-item.picked { border-color: rgba(168,85,247,0.15); }

.wday-label { font-size: 16rpx; color: rgba(224,224,255,0.3); }
.wday-num { font-size: 18rpx; color: rgba(224,224,255,0.5); font-weight: bold; margin-bottom: 4rpx; }

.wday-card-wrap { width: 88rpx; height: 132rpx; position: relative; }
.wday-card-img {
  width: 88rpx; height: 132rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(0,240,255,0.15);
}
.wday-card-img.reversed { transform: rotate(180deg); }
.wday-card-empty {
  width: 88rpx; height: 132rpx;
  border-radius: 10rpx;
  border: 1rpx dashed rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.02);
  display: flex; align-items: center; justify-content: center;
}
.wday-empty-icon { font-size: 36rpx; color: rgba(255,255,255,0.08); }

.wday-name {
  font-size: 14rpx; color: rgba(0,240,255,0.5);
  text-align: center; white-space: normal;
  word-break: break-all; line-height: 1.3;
  max-width: 100rpx;
}
.wday-name-dim { font-size: 16rpx; color: rgba(255,255,255,0.1); }

/* ====== Share Card Modal ====== */
.sc-mask {
  position: fixed; left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.85);
  display: flex; align-items: flex-end; justify-content: center;
  z-index: 1000;
}
.sc-panel {
  /* 固定高度，小程序 scroll-view 必须能推算出明确高度才能滚动 */
  position: fixed; bottom: 0; left: 0; right: 0;
  height: 90vh;
  background: #0d0d1e;
  border-radius: 40rpx 40rpx 0 0;
  padding: 20rpx 0 0;
  display: flex; flex-direction: column; align-items: center;
  border-top: 1rpx solid rgba(0,240,255,0.12);
  box-sizing: border-box;
}
.sc-close {
  position: absolute; top: 28rpx; left: 32rpx;
  width: 60rpx; height: 60rpx; border-radius: 50%;
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.1);
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; color: rgba(224,224,255,0.5); line-height: 1;
  text-align: center;
}
.sc-top-label {
  display: block; text-align: center;
  font-size: 18rpx; color: rgba(224,224,255,0.2); letter-spacing: 3rpx;
  margin-bottom: 20rpx;
}

/* 卡片预览滚动区：90vh - 顶部label(60rpx) - 按钮区(130rpx) - 提示文字(60rpx) - padding(20rpx) */
.sc-scroll { width: 100%; height: calc(90vh - 270rpx); }
.sc-scroll-padding { height: 24rpx; }

.sc-card-wrap {
  margin: 0 32rpx; border-radius: 28rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255,255,255,0.08);
}
.sc-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 28rpx 12rpx;
  background: linear-gradient(180deg, rgba(10,10,15,1), rgba(16,16,40,1));
}
.sc-brand { font-size: 16rpx; color: rgba(255,255,255,0.15); letter-spacing: 6rpx; }
.sc-date-label { font-size: 18rpx; color: rgba(255,255,255,0.3); }

.sc-fortune-label-row {
  padding: 0 28rpx 16rpx;
  background: linear-gradient(180deg, rgba(16,16,40,1), rgba(12,12,30,1));
  display: flex; align-items: center;
}
.sc-stamp {
  font-size: 22rpx; font-weight: bold;
  color: rgba(233,69,96,0.85);
  border: 2rpx solid rgba(233,69,96,0.35);
  border-radius: 8rpx; padding: 4rpx 20rpx;
  transform: rotate(-2deg);
  display: inline-block;
}

.sc-card-face {
  display: flex; justify-content: center; align-items: center;
  padding: 20rpx 0 28rpx;
  background: linear-gradient(180deg, rgba(12,12,30,1), rgba(16,16,42,1));
}
.sc-divider {
  height: 1rpx; margin: 0 28rpx;
  background: rgba(255,255,255,0.06);
}
.sc-fortune-text {
  display: block; padding: 28rpx 28rpx 24rpx;
  font-size: 26rpx; color: rgba(224,224,255,0.65);
  line-height: 1.85; text-align: center;
  white-space: pre-wrap; word-break: break-word;
  background: rgba(16,16,42,1);
}
.sc-footer {
  display: flex; align-items: flex-end; justify-content: space-between;
  padding: 12rpx 28rpx 24rpx;
  background: rgba(10,10,24,1);
  border-top: 1rpx solid rgba(255,255,255,0.05);
}
.sc-footer-left { display: flex; flex-direction: column; gap: 4rpx; }
.sc-gz { font-size: 18rpx; color: rgba(255,184,0,0.3); }
.sc-card-name { font-size: 18rpx; color: rgba(0,240,255,0.3); }
.sc-site { font-size: 16rpx; color: rgba(255,255,255,0.1); }

/* 操作按钮 */
.sc-actions {
  display: flex; gap: 20rpx;
  padding: 24rpx 32rpx 8rpx; width: 100%;
}
.sc-btn-save {
  flex: 1; padding: 28rpx 0; border-radius: 20rpx; text-align: center;
  background: linear-gradient(135deg, rgba(0,240,255,0.12), rgba(168,85,247,0.12));
  border: 1rpx solid rgba(0,240,255,0.25);
  color: rgba(0,240,255,0.85); font-size: 26rpx; font-weight: bold;
  transition: opacity 0.2s;
}
.sc-btn-save.loading { opacity: 0.5; }
.sc-btn-share {
  flex: 1; padding: 28rpx 0; border-radius: 20rpx; text-align: center;
  background: rgba(233,69,96,0.08);
  border: 1rpx solid rgba(233,69,96,0.25) !important;
  color: rgba(233,69,96,0.8) !important; font-size: 26rpx; font-weight: bold;
  line-height: 1;
  /* reset button默认样式 */
  margin: 0 !important; min-width: 0 !important;
  box-sizing: border-box !important;
}
.sc-btn-share::after { border: none !important; }
.sc-hint {
  display: block; text-align: center;
  font-size: 18rpx; color: rgba(224,224,255,0.18);
  padding: 4rpx 0 env(safe-area-inset-bottom, 24rpx);
}

/* Modal */
.modal-mask {
  position: fixed;
  left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 999;
}
.modal-panel {
  width: 100%;
  max-width: 680rpx;
  border-radius: 36rpx 36rpx 0 0;
  padding: 28rpx 32rpx 36rpx;
}
.modal-title { display:block; text-align:center; font-size: 30rpx; margin-bottom: 8rpx; }
.modal-sub { display:block; text-align:center; font-size: 18rpx; color: rgba(224,224,255,0.3); margin-bottom: 20rpx; }
.form-row { margin-bottom: 16rpx; }
.form-grid { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.form-row.half { flex: 1; }
.label { display:block; font-size: 18rpx; color: rgba(224,224,255,0.3); margin-bottom: 8rpx; }
.picker, .input { padding: 18rpx 20rpx; border-radius: 16rpx; color: rgba(224,224,255,0.7); font-size: 22rpx; }
.btns { display:flex; gap: 16rpx; margin-top: 10rpx; }
.btns .btn-primary { flex: 1; }
.btns .btn-secondary { flex: 0 0 180rpx; }
.modal-foot { display:block; text-align:center; font-size: 16rpx; color: rgba(224,224,255,0.12); margin-top: 16rpx; }
