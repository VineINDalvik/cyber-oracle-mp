.page {
  display: flex; flex-direction: column; align-items: center;
  min-height: 100vh; padding: 32rpx 32rpx 160rpx;
}
.page-title { display: block; font-size: 36rpx; font-weight: bold; margin: 8rpx 0 28rpx; letter-spacing: 8rpx; }
.spread-list { width: 100%; margin-bottom: 40rpx; }
.spread-item { width: 100%; padding: 24rpx; border-radius: 20rpx; margin-bottom: 16rpx; }
.spread-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8rpx; }
.spread-name { font-size: 28rpx; font-weight: bold; color: var(--neon-cyan); }
.spread-count { font-size: 20rpx; color: rgba(224,224,255,0.2); }
.spread-desc { font-size: 22rpx; color: rgba(224,224,255,0.3); }
.topic-section { width: 100%; }
.topic-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 20rpx; }
.topic-tag {
  font-size: 16rpx; padding: 4rpx 12rpx; border-radius: 8rpx;
  background: rgba(255,184,0,0.05); border: 1rpx solid rgba(255,184,0,0.15);
  color: rgba(255,184,0,0.6);
}
.topic-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.topic-item {
  display: flex; align-items: center; gap: 16rpx;
  padding: 24rpx 20rpx; border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
  position: relative; overflow: hidden;
}
.topic-bar {
  position: absolute; left: 0; top: 0; bottom: 0;
  width: 6rpx; border-radius: 6rpx 0 0 6rpx;
}
.topic-love { background: rgba(255,80,120,0.06); }
.topic-love .topic-bar { background: rgba(255,80,120,0.5); }
.topic-love .topic-name { color: rgba(255,140,170,0.9); }
.topic-career { background: rgba(255,184,0,0.06); }
.topic-career .topic-bar { background: rgba(255,184,0,0.5); }
.topic-career .topic-name { color: rgba(255,210,80,0.9); }
.topic-wealth { background: rgba(0,200,120,0.06); }
.topic-wealth .topic-bar { background: rgba(0,200,120,0.5); }
.topic-wealth .topic-name { color: rgba(80,220,160,0.9); }
.topic-health { background: rgba(0,180,255,0.06); }
.topic-health .topic-bar { background: rgba(0,180,255,0.5); }
.topic-health .topic-name { color: rgba(80,200,255,0.9); }
.topic-social { background: rgba(160,100,255,0.06); }
.topic-social .topic-bar { background: rgba(160,100,255,0.5); }
.topic-social .topic-name { color: rgba(190,150,255,0.9); }
.topic-open { background: rgba(0,240,255,0.04); }
.topic-open .topic-bar { background: rgba(0,240,255,0.4); }
.topic-open .topic-name { color: rgba(0,240,255,0.8); }
.topic-left { flex-shrink: 0; }
.topic-icon { font-size: 44rpx; display: block; }
.topic-right { flex: 1; min-width: 0; }
.topic-name { display: block; font-size: 26rpx; font-weight: bold; color: rgba(224,224,255,0.8); }
.topic-desc { display: block; font-size: 18rpx; color: rgba(224,224,255,0.25); margin-top: 4rpx; }
.topic-arrow { font-size: 32rpx; color: rgba(224,224,255,0.15); flex-shrink: 0; }

.shuffling { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh; }
/* ─── 自由提问输入页 ─────────────────────── */
.question-view {
  display: flex; flex-direction: column; align-items: center;
  width: 100%; max-width: 600rpx; margin: 0 auto;
}
.question-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.question-hint { font-size: 22rpx; color: rgba(224,224,255,0.3); margin-bottom: 32rpx; }
.question-input {
  width: 100%; min-height: 160rpx; padding: 24rpx;
  border-radius: 20rpx; font-size: 28rpx;
  color: rgba(224,224,255,0.7); line-height: 1.6;
}
.question-count {
  display: block; width: 100%; text-align: right;
  font-size: 18rpx; color: rgba(224,224,255,0.15); margin-top: 8rpx;
}
.question-btn {
  width: 100%; padding: 24rpx; border-radius: 20rpx; text-align: center;
  background: linear-gradient(to right, rgba(0,240,255,0.12), rgba(140,80,255,0.12));
  border: 1rpx solid rgba(0,240,255,0.2);
  color: rgba(0,240,255,0.9); font-size: 26rpx; margin-top: 24rpx;
}
.question-btn.disabled { opacity: 0.3; }
.question-echo {
  width: 100%; padding: 16rpx 20rpx; border-radius: 16rpx; margin-bottom: 16rpx;
}
.question-echo-label { font-size: 18rpx; color: rgba(224,224,255,0.2); }
.question-echo-text { font-size: 22rpx; color: rgba(224,224,255,0.45); }

.topic-shuffle-icon { font-size: 60rpx; margin-bottom: 24rpx; display: block; text-align: center; }
.shuffle-cards { display: flex; gap: 12rpx; margin-bottom: 24rpx; }
.shuffle-text { font-size: 22rpx; }

.reveal-header { text-align: center; margin-bottom: 12rpx; }
.reveal-title { font-size: 28rpx; font-weight: bold; display: block; }
.reveal-hint { display: block; text-align: center; font-size: 20rpx; color: rgba(224,224,255,0.3); margin-bottom: 24rpx; }

/* ─── 散牌桌面 ───────────────────────── */
.table-hint {
  display: block; text-align: center; font-size: 20rpx;
  color: rgba(224,224,255,0.3); margin-bottom: 16rpx;
}
.table-progress {
  display: block; text-align: center; font-size: 24rpx;
  color: rgba(0,240,255,0.6); margin-bottom: 20rpx;
}
.card-table {
  display: flex; flex-wrap: wrap; justify-content: center;
  gap: 16rpx; padding: 40rpx 20rpx;
  border-radius: 24rpx;
  background: radial-gradient(ellipse at center, rgba(0,240,255,0.03) 0%, transparent 70%);
  border: 1rpx solid rgba(255,255,255,0.04);
  margin-bottom: 20rpx; width: 100%;
}
.table-card {
  transition: transform 0.3s ease, opacity 0.3s ease;
}
.table-card-gone {
  opacity: 0;
  transform: scale(0.6) rotate(0deg) !important;
  pointer-events: none;
}
.reshuffle-btn {
  display: block; text-align: center; font-size: 22rpx;
  color: rgba(0,240,255,0.5); padding: 12rpx 24rpx;
  border: 1rpx solid rgba(0,240,255,0.15); border-radius: 12rpx;
  margin-bottom: 8rpx;
}
.reshuffle-btn.disabled { opacity: 0.2; pointer-events: none; }

/* ─── 牌位进度面板 ───────────────────── */
.slot-panel {
  width: 100%; display: flex; gap: 12rpx; flex-wrap: wrap;
  justify-content: center; margin-bottom: 20rpx;
}
.slot-panel-done { margin-bottom: 24rpx; }
.slot-item {
  display: flex; flex-direction: column; align-items: center;
  padding: 12rpx 16rpx; border-radius: 12rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
  background: rgba(18,18,31,0.5);
  min-width: 120rpx; transition: all 0.3s ease;
}
.slot-item.slot-active {
  border-color: rgba(0,240,255,0.4);
  background: rgba(0,240,255,0.06);
  box-shadow: 0 0 12rpx rgba(0,240,255,0.1);
}
.slot-item.slot-filled {
  border-color: rgba(140,80,255,0.3);
  background: rgba(140,80,255,0.06);
}
.slot-pos { font-size: 16rpx; color: rgba(224,224,255,0.3); margin-bottom: 4rpx; }
.slot-card { display: flex; align-items: center; gap: 4rpx; }
.slot-card-name { font-size: 18rpx; color: rgba(0,240,255,0.7); }
.slot-card-state {
  font-size: 14rpx; padding: 1rpx 6rpx; border-radius: 4rpx;
  background: rgba(255,80,120,0.1); color: rgba(255,80,120,0.7);
}
.slot-empty { font-size: 24rpx; color: rgba(224,224,255,0.1); }

/* ─── 三体面板 ─────────────────────────── */
.trinity-panel { width: 100%; margin-bottom: 24rpx; }
.trinity-row { display: flex; gap: 16rpx; margin-bottom: 12rpx; }
.hex-box { flex: 1; padding: 20rpx; border-radius: 16rpx; }
.hex-top { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.hex-symbol { font-size: 48rpx; }
.hex-name { font-size: 24rpx; font-weight: bold; display: block; }
.hex-trigrams { font-size: 18rpx; color: rgba(224,224,255,0.2); display: block; }
.hex-desc { font-size: 18rpx; color: rgba(224,224,255,0.3); line-height: 1.5; }
.gz-box {
  width: 180rpx; padding: 20rpx; border-radius: 16rpx;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.gz-day { font-size: 18rpx; color: rgba(0,240,255,0.6); margin-bottom: 6rpx; }
.gz-element { font-size: 32rpx; font-weight: bold; }
.gz-wuxing { font-size: 16rpx; color: rgba(224,224,255,0.2); }
.gz-detail { font-size: 16rpx; color: rgba(224,224,255,0.15); margin-top: 4rpx; }
.wuxing-analysis {
  padding: 18rpx 20rpx; border-radius: 12rpx; margin-bottom: 12rpx;
  background: rgba(255,184,0,0.03); border: 1rpx solid rgba(255,184,0,0.1);
}
.wuxing-label { font-size: 18rpx; color: rgba(255,184,0,0.5); display: block; margin-bottom: 6rpx; }
.wuxing-text { font-size: 20rpx; color: rgba(224,224,255,0.4); line-height: 1.6; }
.trinity-tags {
  display: flex; align-items: center; justify-content: center; gap: 16rpx; padding: 8rpx 0;
}
.tag-zhouyi {
  font-size: 16rpx; padding: 4rpx 14rpx; border-radius: 8rpx;
  background: rgba(255,184,0,0.05); color: rgba(255,184,0,0.4); border: 1rpx solid rgba(255,184,0,0.1);
}
.tag-wuxing {
  font-size: 16rpx; padding: 4rpx 14rpx; border-radius: 8rpx;
  background: rgba(0,240,255,0.05); color: rgba(0,240,255,0.4); border: 1rpx solid rgba(0,240,255,0.1);
}
.tag-tarot {
  font-size: 16rpx; padding: 4rpx 14rpx; border-radius: 8rpx;
  background: rgba(140,80,255,0.05); color: rgba(140,80,255,0.4); border: 1rpx solid rgba(140,80,255,0.1);
}
.tag-sep { font-size: 16rpx; color: rgba(224,224,255,0.1); }

.cards-row { display: flex; align-items: flex-start; justify-content: center; gap: 24rpx; flex-wrap: wrap; margin-bottom: 24rpx; }
.card-slot { display: flex; flex-direction: column; align-items: center; }
.pos-label { font-size: 20rpx; color: rgba(0,240,255,0.5); margin-bottom: 12rpx; }
.card-label { font-size: 20rpx; color: var(--neon-cyan); margin-top: 12rpx; }
.card-reversed { font-size: 16rpx; color: var(--neon-pink); }
/* 免费简读 */
.brief-reading { width: 100%; padding: 28rpx; border-radius: 20rpx; margin-bottom: 16rpx; }
.brief-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 20rpx; }
.brief-tag {
  font-size: 18rpx; padding: 4rpx 14rpx; border-radius: 8rpx;
  background: rgba(0,240,255,0.05); color: rgba(0,240,255,0.6); border: 1rpx solid rgba(0,240,255,0.1);
}
.brief-free { font-size: 18rpx; color: rgba(224,224,255,0.2); }
.brief-text { font-size: 28rpx; color: rgba(224,224,255,0.6); line-height: 2; white-space: pre-wrap; }

/* 付费引导 */
.deep-teaser {
  width: 100%; padding: 24rpx; border-radius: 20rpx; margin-bottom: 20rpx;
  background: linear-gradient(to right, rgba(255,184,0,0.05), rgba(140,80,255,0.05));
  border: 1rpx dashed rgba(255,184,0,0.15);
}
.btn-gold {
  width: 100%; padding: 24rpx; border-radius: 20rpx; text-align: center;
  background: linear-gradient(to right, rgba(255,184,0,0.15), rgba(140,80,255,0.15));
  border: 1rpx solid rgba(255,184,0,0.2);
  color: rgba(255,184,0,0.9); font-size: 24rpx; margin-bottom: 16rpx;
}
.deep-label { display: flex; align-items: center; gap: 12rpx; margin-bottom: 20rpx; }
.deep-tag {
  font-size: 18rpx; padding: 4rpx 14rpx; border-radius: 8rpx;
  background: rgba(255,184,0,0.05); color: rgba(255,184,0,0.6); border: 1rpx solid rgba(255,184,0,0.1);
}
.deep-sub { font-size: 18rpx; color: rgba(224,224,255,0.15); }

.teaser { width: 100%; padding: 24rpx; border-radius: 20rpx; margin-bottom: 20rpx; border-style: dashed; }
.teaser-text { font-size: 24rpx; color: rgba(224,224,255,0.4); line-height: 1.6; text-align: center; }
.back-btn { display: block; text-align: center; font-size: 22rpx; color: rgba(224,224,255,0.15); margin-top: 24rpx; padding: 8rpx; }
.share-row { width: 100%; display: flex; flex-direction: column; align-items: center; }
.share-btn-draw {
  width: 100%; padding: 24rpx 0 !important; border-radius: 20rpx !important;
  background: rgba(18,18,31,0.8) !important;
  border: 1rpx solid rgba(0,240,255,0.1) !important;
  color: rgba(224,224,255,0.4) !important; font-size: 24rpx !important;
}
.reset-btn { display: block; text-align: center; font-size: 22rpx; color: rgba(224,224,255,0.15); margin-top: 16rpx; padding: 16rpx; }
.reading, .glass-no-blur {
  width: 100%; padding: 28rpx; border-radius: 20rpx; margin-top: 24rpx;
  min-height: 200rpx;
  background: rgba(18,18,31,0.92);
  border: 1rpx solid rgba(255,255,255,0.08);
}
.reading-text { font-size: 28rpx; color: rgba(224,224,255,0.7); line-height: 2; white-space: pre-wrap; word-break: break-word; }
.loading-text { font-size: 22rpx; color: rgba(224,224,255,0.3); text-align: center; display: inline; }
.loading-text-wrap { display: flex; align-items: center; justify-content: center; }

/* ─── Streaming 光标 ─────────────────── */
.stream-cursor {
  display: inline; font-size: 28rpx;
  color: rgba(0,240,255,0.8);
  animation: blink-cursor 0.8s steps(2) infinite;
}
@keyframes blink-cursor {
  0% { opacity: 1; }
  100% { opacity: 0; }
}
